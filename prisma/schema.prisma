model ConcernUpdate {
  id            Int           @id @default(autoincrement())
  updateMessage String
  media         Media[]
  status        ConcernStatus
  createdAt     DateTime      @default(now())
  concernId     Int
  concern       Concern       @relation("ConcernUpdates", fields: [concernId], references: [id])
}

model Media {
  id                 String              @id @default(cuid())
  name               String?
  url                String
  isAI               Boolean             @default(false)
  type               MediaType
  for                MediaFor?
  verificationStatus VerificationStatus? @default(pending)
  // Owner (Resident who uploaded) 
  ownerId            Int?                @unique
  owner              User?               @relation("UserVerificationMedia", fields: [ownerId], references: [id])
  // Reviewer (Admin who reviewed) 
  reviewedById       Int?
  reviewedBy         User?               @relation("MediaReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt         DateTime?
  fileType           String?
  fileSize           Int?
  summonId           Int?
  concernId          Int?
  concern            Concern?            @relation(fields: [concernId], references: [id])
  concernMessagesId  Int?
  //concernMessages    ConcernMessage?     @relation("ConcernMessagesMedia", fields: [concernMessagesId], references: [id])
  feedbackId         Int?
  feedback           Feedback?           @relation(fields: [feedbackId], references: [id])
  concernUpdate      ConcernUpdate?      @relation(fields: [concernUpdateId], references: [id])
  concernUpdateId    Int?
}

enum VerificationStatus {
  pending
  rejected
  approved
}

enum MediaFor {
  concern
  announcement
  userverification
}

model Category {
  id          Int          @id @default(autoincrement())
  description String?
  name        String
  type        CategoryType @default(concern)
  Concern     Concern[]    @relation("ConcernCategory")
  feedback    Feedback[]   @relation("feedbackCategory")
  createdAt   DateTime     @default(now())
}

enum CategoryType {
  concern
  feedback
}

model Feedback {
  //Fields
  id               Int             @id @default(autoincrement())
  title            String
  isSpam           Boolean         @default(false)
  issuedAt         DateTime        @default(now())
  updatedAt        DateTime?       @updatedAt
  star             Float?
  categoryId       Int?
  category         Category?       @relation("feedbackCategory", fields: [categoryId], references: [id])
  other            String?
  //Relationships
  userId           Int
  user             User            @relation("UserFeedbacks", fields: [userId], references: [id])
  //concernId Int
  //concern   Concern   @relation("ConcernFeedback", fields: [concernId], references: [id])
  media            Media[]
  feedback         String
  feedbackUpdateId Int?
  feedbackUpdate   FeedbackUpdate? @relation(fields: [feedbackUpdateId], references: [id])
}

model FeedbackUpdate {
  id Int @id @default(autoincrement())

  feedbackMessage String
  createdAt       DateTime @default(now())

  feedbacks Feedback[]
}

model Notification {
  id        Int              @id @default(autoincrement())
  type      NotificationType
  itemId    Int?
  message   String?
  url       String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  userId    Int
  user      User             @relation("UserNotifications", fields: [userId], references: [id])
}

model SystemFeedback {
  id      Int    @id @default(autoincrement())
  message String
  userId  Int
  user    User   @relation("UserSystemFeedback", references: [id], fields: [userId])
}

model Announcement {
  id              Int       @id @default(autoincrement())
  title           String
  content         String
  notifyOfficials Boolean   @default(false)
  notifyResidents Boolean   @default(false)
  userId          Int
  user            User      @relation("UserAnnouncement", fields: [userId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime? @updatedAt
}
