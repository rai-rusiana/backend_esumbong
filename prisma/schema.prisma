generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  admin
  resident
  barangay_official
}

enum NotificationType {
  concern
  feedback
  summons
  mediation
  update
  alert
  announcement
  userVerification
}

enum ConcernStatus {
  pending
  inProgress
  verified
  canceled
  approved
  rejected
  resolved
  unresolved
}

enum Validation {
  pending
  approved
  rejected
}

model User {
  //Fields
  id              Int              @id @default(autoincrement())
  fullname        String
  email           String           @unique
  password        String
  address         String
  profilePhoto    String?
  position        String?
  age             Int?
  contactNumber   String
  type            UserType         @default(admin)
  createAt        DateTime         @default(now())
  isVerified      Boolean          @default(false)
  isActive        Boolean          @default(true)
  isOpen          Boolean          @default(false)
  dailyPostCount  Int              @default(0)
  lastPostReset   DateTime         @default(now())
  barangay        String?
  isLocked        Boolean          @default(false)
  unlockTime      DateTime?
  loginAttempts   Int              @default(0)
  // ERD
  // Resident Side
  residentConcern Concern[]        @relation("ResidentReports")
  //Polymorphic
  userFeedback    Feedback[]       @relation("UserFeedbacks")
  noticication    Notification[]   @relation("UserNotifications")
  SystemFeedback  SystemFeedback[] @relation("UserSystemFeedback")

  validatedConcerns Concern[]      @relation("ValidatedConcern")
  archivedConcerns  Concern[]      @relation("ArchivedConcern")
  userAnnouncement  Announcement[] @relation("UserAnnouncement")
  assignedTo        Concern[]      @relation("AssignedConcern")

  // Verification uploads (Resident side) 
  verificationMedia Media?  @relation("UserVerificationMedia")
  // Reviewed media (Admin side) 
  reviewedMedia     Media[] @relation("MediaReviewedBy")
  //concernMessages   ConcernMessage[] @relation("UserConcernMessages")
}

enum MediaType {
  photo
  video
  file
}

model Concern {
  id                      Int             @id @default(autoincrement())
  title                   String?
  details                 String
  location                String?
  categoryId              Int?
  // validation 
  isAnonymous             Boolean         @default(false)
  isSpam                  Boolean         @default(false)
  needsBarangayAssistance Boolean         @default(false)
  isArchived              Boolean         @default(false)
  ArchivedById            Int?
  ArchivedBy              User?           @relation("ArchivedConcern", fields: [ArchivedById], references: [id])
  archivedOn              DateTime?
  validation              Validation      @default(pending)
  validatedById           Int?
  validatedBy             User?           @relation("ValidatedConcern", fields: [validatedById], references: [id])
  validatedAt             DateTime?
  assinedToId             Int?
  assignedTo              User?           @relation("AssignedConcern", fields: [assinedToId], references: [id])
  media                   Media[]
  category                Category?       @relation("ConcernCategory", fields: [categoryId], references: [id])
  other                   String?
  status                  ConcernStatus   @default(pending)
  userId                  Int
  user                    User            @relation("ResidentReports", fields: [userId], references: [id])
  updatedAt               DateTime?       @updatedAt
  issuedAt                DateTime        @default(now())
  updates                 ConcernUpdate[] @relation("ConcernUpdates")
  //concernMessages         ConcernMessage[] @relation("ConcernMessages")
}

